<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | MiSitio Express</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <%- include('../partials/header') %>

    <section class="hero-section text-center">
        <div class="container position-relative" style="z-index: 2;">
            <h1 class="display-4 fw-bold mb-3">Bienvenido a <span class="text-info">Nuestra Plataforma</span></h1>
            <p class="lead mb-4 opacity-75">Desarrollo web moderno, escalable y profesional con Express & EJS</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/nosotros" class="btn btn-info btn-lg px-4 shadow">Conoce más</a>
                <a href="/contacto" class="btn btn-outline-light btn-lg px-4">Contáctanos</a>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row g-4 mt-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center p-4">
                        <div class="feature-icon bg-info bg-opacity-10 text-info mx-auto"><i class="bi bi-lightning-charge-fill"></i></div>
                        <h5 class="fw-bold">Rápido & Ligero</h5>
                        <p class="text-muted mb-0">Renderizado en servidor optimizado para bajo consumo de recursos.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center p-4">
                        <div class="feature-icon bg-success bg-opacity-10 text-success mx-auto"><i class="bi bi-puzzle-fill"></i></div>
                        <h5 class="fw-bold">Modular</h5>
                        <p class="text-muted mb-0">Arquitectura basada en parciales y rutas independientes.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center p-4">
                        <div class="feature-icon bg-warning bg-opacity-10 text-warning mx-auto"><i class="bi bi-palette-fill"></i></div>
                        <h5 class="fw-bold">Bootstrap 5</h5>
                        <p class="text-muted mb-0">Diseño responsivo, accesible y listo para producción.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>